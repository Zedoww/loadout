<Application x:Class="Opti.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:Opti.App"
             xmlns:conv="clr-namespace:Opti.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <conv:BytesToReadableConverter x:Key="BytesToReadable" />
            <conv:NullableFloatConverter x:Key="NullableFloat" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
