<ui:FluentWindow x:Class="Loadout.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:views="clr-namespace:Loadout.App.Views"
                 Title="Loadout"
                 Width="1040" Height="700"
                 MinWidth="860" MinHeight="580"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 Background="{StaticResource Bg.Window}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar with the brand wordmark -->
        <ui:TitleBar Grid.Row="0" Icon="{x:Null}" Height="48">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="6"
                            Background="{StaticResource Brand.Gradient}">
                        <TextBlock Text="L" FontFamily="{StaticResource Font.Display}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="LOADOUT" Margin="10,0,0,0" VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Display}"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource Brand.Gradient}" />
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           OpenPaneLength="216">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard"
                                       TargetPageType="{x:Type views:DashboardPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Gauge24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Surge"
                                       TargetPageType="{x:Type views:SurgePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Rocket24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Processes"
                                       TargetPageType="{x:Type views:ProcessesPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="WindowApps24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Tweaks"
                                       TargetPageType="{x:Type views:TweaksPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Options24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Cleanup"
                                       TargetPageType="{x:Type views:CleanupPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="System Info"
                                       TargetPageType="{x:Type views:SystemInfoPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DesktopPulse24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings"
                                       TargetPageType="{x:Type views:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
