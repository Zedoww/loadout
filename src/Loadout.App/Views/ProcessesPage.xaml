<Page x:Class="Loadout.App.Views.ProcessesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Processes">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type Page}}}">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Processes" Style="{StaticResource Type.PageTitle}" />
                <TextBlock Text="Pause memory-hungry apps while you game. Suspending is fully reversible — hit Resume to wake them."
                           Style="{StaticResource Type.PageSubtitle}" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Surface}" Padding="14" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Refresh" Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding RefreshCommand}" Margin="0,0,10,0" />
                    <ui:Button Content="Free memory" Icon="{ui:SymbolIcon Broom24}"
                               Appearance="Primary"
                               Command="{Binding FreeMemoryCommand}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding Summary}" VerticalAlignment="Center"
                               Style="{StaticResource Type.Body}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Surface}" Padding="8">
                <ItemsControl ItemsSource="{Binding Processes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Surface.Row}" Padding="14,11" Margin="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{StaticResource Text.Primary}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding MemoryText}"
                                                       FontFamily="{StaticResource Font.Mono}" FontSize="12"
                                                       Foreground="{StaticResource Text.Secondary}" />
                                            <TextBlock Text="  ·  " Foreground="{StaticResource Text.Tertiary}" />
                                            <TextBlock Text="{Binding CountText}" Style="{StaticResource Type.Caption}" />
                                            <TextBlock Text="{Binding Status}" Margin="10,0,0,0"
                                                       Foreground="{StaticResource Success}" FontSize="12" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Paused badge, shown only while suspended -->
                                    <Border Grid.Column="1" Style="{StaticResource Pill}" Background="#33F6B73C"
                                            Margin="0,0,10,0"
                                            Visibility="{Binding IsSuspended, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Paused" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Warning}" />
                                    </Border>

                                    <!-- One stateful toggle: Suspend ⇄ Resume -->
                                    <ui:Button Grid.Column="2" MinWidth="104"
                                               Content="{Binding ButtonText}"
                                               Command="{Binding ToggleCommand}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
