<Page x:Class="Loadout.App.Views.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Cleanup">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type Page}}}">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Cleanup" Style="{StaticResource Type.PageTitle}" />
                <TextBlock Text="Preview each category, then delete only what you pick. Files in use are safely skipped."
                           Style="{StaticResource Type.PageSubtitle}" Margin="0,4,0,0" />

                <!-- Select all + live total -->
                <DockPanel Margin="0,14,0,0">
                    <CheckBox DockPanel.Dock="Left" Content="Select all"
                              IsChecked="{Binding IsAllSelected}" />
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Text="{Binding SelectedTotalText}" VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Mono}" FontSize="12.5"
                               Foreground="{StaticResource Text.Secondary}" />
                </DockPanel>
            </StackPanel>

            <!-- Category list -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Categories}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Surface.Row}" Padding="16,12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="0,0,12,0" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource Type.CardTitle}" />
                                        <Border Style="{StaticResource Pill}" Background="#33F6B73C" Margin="10,1,0,0"
                                                Visibility="{Binding IsCaution, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="Caution" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Warning}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Type.Caption}"
                                               Margin="0,2,16,0" TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center"
                                           FontFamily="{StaticResource Font.Mono}" FontSize="14"
                                           Foreground="{StaticResource Text.Primary}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Actions -->
            <ui:Card Grid.Row="2" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding ScanSummary}" Style="{StaticResource Type.Body}"
                               FontSize="14" Margin="0,0,0,16" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Scan" Icon="{ui:SymbolIcon Search24}"
                                   Command="{Binding ScanCommand}"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                   Margin="0,0,12,0" />
                        <ui:Button Content="Clean selected" Icon="{ui:SymbolIcon Broom24}"
                                   Appearance="Primary"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                   Command="{Binding CleanCommand}" Margin="0,0,12,0" />
                        <ui:Button Content="Restore point" Icon="{ui:SymbolIcon ShieldCheckmark24}"
                                   IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                   Command="{Binding CreateRestorePointCommand}" />
                    </StackPanel>
                    <ui:ProgressRing IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,16,0,0" HorizontalAlignment="Left" />
                </StackPanel>
            </ui:Card>

            <Border Grid.Row="3" Style="{StaticResource Surface}" Padding="16" MinHeight="80">
                <ItemsControl ItemsSource="{Binding Log}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,3"
                                       FontFamily="{StaticResource Font.Mono}" FontSize="12.5"
                                       Foreground="{StaticResource Text.Secondary}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
