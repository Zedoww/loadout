<Page x:Class="Loadout.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">

    <Grid Margin="28,24,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Settings" Style="{StaticResource Type.PageTitle}" />
        </StackPanel>

        <ui:Card Grid.Row="1" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dark theme" Style="{StaticResource Type.CardTitle}" FontSize="15" />
                    <TextBlock Text="Switch between the dark and light appearance."
                               Style="{StaticResource Type.Body}" Margin="0,2,0,0" />
                </StackPanel>
                <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                 IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
            </Grid>
        </ui:Card>

        <ui:Card Grid.Row="2" Padding="20">
            <StackPanel>
                <TextBlock Text="About" Style="{StaticResource Type.CardTitle}" FontSize="15" Margin="0,0,0,8" />
                <TextBlock Style="{StaticResource Type.Body}">
                    <Run Text="Loadout" FontWeight="SemiBold" Foreground="{StaticResource Brand.Primary}" />
                    <Run Text="— safe, reversible PC optimization for gaming." />
                </TextBlock>
                <TextBlock Margin="0,4,0,0" Style="{StaticResource Type.Caption}">
                    <Run Text="Version" />
                    <Run Text="{Binding Version, Mode=OneWay}" />
                    <Run Text="· MIT license" />
                </TextBlock>
                <ui:HyperlinkButton Margin="0,8,0,0"
                                    Content="github.com/Zedoww/loadout"
                                    NavigateUri="{Binding RepositoryUrl}" />
            </StackPanel>
        </ui:Card>
    </Grid>
</Page>
