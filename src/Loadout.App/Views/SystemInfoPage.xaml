<Page x:Class="Loadout.App.Views.SystemInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="System Info">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType={x:Type Page}}}">
        <Grid Margin="28,24,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="System Configuration" Style="{StaticResource Type.PageTitle}" />
                    <TextBlock Text="Complete hardware and software inventory of this machine."
                               Style="{StaticResource Type.PageSubtitle}" Margin="0,4,0,0" />
                </StackPanel>
                <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Top"
                           Command="{Binding RefreshCommand}" Appearance="Primary"
                           IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" Margin="0,0,6,0" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </ui:Button>
            </DockPanel>

            <!-- Loading indicator -->
            <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center" Margin="0,40,0,40">
                <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40" />
                <TextBlock Text="Collecting system information…" Style="{StaticResource Type.Body}"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVis}}">

                <!-- ═══════════ OS ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Desktop24" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Operating System" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="VERSION" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding OsName}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="BUILD" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding OsBuild}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="ARCHITECTURE" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding Architecture}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="COMPUTER" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding ComputerName}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="USER" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding UserName}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="INSTALL DATE" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding InstallDate}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="LAST BOOT" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding LastBoot}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════ CPU ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Processor" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="MODEL" Style="{StaticResource Type.Caption}" />
                            <TextBlock Text="{Binding CpuName}" Style="{StaticResource Type.Body}"
                                       Foreground="{StaticResource Text.Primary}" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CORES" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding CpuCores}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="THREADS" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding CpuThreads}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BASE CLOCK" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding CpuBaseClock}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="CACHE" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding CpuCache}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════ GPU ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Games24" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Graphics" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="MODEL" Style="{StaticResource Type.Caption}" />
                            <TextBlock Text="{Binding GpuName}" Style="{StaticResource Type.Body}"
                                       Foreground="{StaticResource Text.Primary}" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="VRAM" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding GpuVram}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="DRIVER" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding GpuDriver}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="RESOLUTION" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding GpuResolution}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Mono}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════ RAM ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Ram20" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Memory" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="TOTAL" Style="{StaticResource Type.Caption}" />
                            <TextBlock Text="{Binding RamTotal}" Style="{StaticResource Type.Body}"
                                       Foreground="{StaticResource Text.Primary}" FontSize="14" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="MODULES" Style="{StaticResource Type.Caption}" />
                            <TextBlock Text="{Binding RamSticks}" Style="{StaticResource Type.Body}"
                                       Foreground="{StaticResource Text.Primary}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══════════ Storage ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Storage24" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Storage" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock Text="{Binding StorageSummary}" Style="{StaticResource Type.Body}"
                                   Foreground="{StaticResource Text.Primary}" />
                    </StackPanel>
                </Border>

                <!-- ═══════════ Motherboard ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Board24" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Motherboard" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MODEL" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding MotherboardName}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="BIOS" Style="{StaticResource Type.Caption}" />
                                <TextBlock Text="{Binding BiosVersion}" Style="{StaticResource Type.Body}"
                                           Foreground="{StaticResource Text.Primary}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ═══════════ Network ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Wifi124" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Network" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock Text="{Binding NetworkSummary}" Style="{StaticResource Type.Body}"
                                   Foreground="{StaticResource Text.Primary}" />
                    </StackPanel>
                </Border>

                <!-- ═══════════ Audio ═══════════ -->
                <Border Style="{StaticResource Surface}" Padding="20" Margin="0,0,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border Width="34" Height="34" CornerRadius="9" Background="#1E2440" DockPanel.Dock="Left">
                                <ui:SymbolIcon Symbol="Speaker224" FontSize="18"
                                               Foreground="{StaticResource Brand.Primary}" />
                            </Border>
                            <TextBlock Text="Audio" Style="{StaticResource Type.CardTitle}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock Text="{Binding AudioDevices}" Style="{StaticResource Type.Body}"
                                   Foreground="{StaticResource Text.Primary}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
